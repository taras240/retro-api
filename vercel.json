{
    "redirects": [
        {
            "source": "/login",
            "destination": "/",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, s-maxage=2592000"
                }
            ]
        }
    ]
}